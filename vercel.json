{
    "version": 2,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/(.*\\.css|.*\\.js|.*\\.svg|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.ico|.*\\.woff2?|.*\\.ttf|.*\\.gif|.*\\.webp)",
            "dest": "/public/$1"
        },
        {
            "src": "/(services|industries|case-studies|pricing|contact|about|admin|admin-login)\\.html",
            "dest": "/public/$1.html"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        }
    ]
}